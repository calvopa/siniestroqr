generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Actores existentes ───────────────────────────────────────────────────────

model Broker {
  id         String      @id @default(cuid())
  nombre     String
  email      String      @unique
  password   String
  telefono   String?
  createdAt  DateTime    @default(now())
  vehiculos  Vehiculo[]
  siniestros Siniestro[]
}

model Vehiculo {
  id        String    @id @default(cuid())
  patente   String    @unique
  marca     String
  modelo    String
  anio      Int
  broker    Broker    @relation(fields: [brokerId], references: [id])
  brokerId  String
  qrTokens  QRToken[]
  createdAt DateTime  @default(now())
}

model QRToken {
  id         String      @id @default(cuid())
  token      String      @unique @default(cuid())
  vehiculo   Vehiculo    @relation(fields: [vehiculoId], references: [id])
  vehiculoId String
  activo     Boolean     @default(true)
  usos       Int         @default(0)
  createdAt  DateTime    @default(now())
  siniestros Siniestro[]
}

// ─── Siniestro ────────────────────────────────────────────────────────────────

model Siniestro {
  id               String             @id @default(cuid())
  token            QRToken            @relation(fields: [tokenId], references: [id])
  tokenId          String
  broker           Broker             @relation(fields: [brokerId], references: [id])
  brokerId         String
  // Conductor tercero
  conductorNombre  String
  conductorDni     String
  conductorTel     String
  conductorEmail   String?
  patenteConductor String
  // Seguro del conductor (texto libre original — nunca eliminar, sirve de fallback)
  companiaSeguros  String
  nroPoliza        String?
  // Vínculo normalizado con Insurer (nullable hasta que corra la migración)
  insurerId        String?
  insurer          Insurer?           @relation(fields: [insurerId], references: [id])
  // Geolocalización
  fechaHora        DateTime           @default(now())
  latitud          Float?
  longitud         Float?
  geoAccuracy      Float?
  geoCapturedAt    DateTime?
  // Contenido
  descripcion      String?
  // Metadatos técnicos
  ipOrigen         String?
  userAgent        String?
  hashDocumento    String?
  estado           String             @default("PENDIENTE")
  createdAt        DateTime           @default(now())
  // Relaciones nuevas
  photos           SiniestroPhoto[]
  accessLogs       InsurerAccessLog[]
}

// ─── Aseguradoras ─────────────────────────────────────────────────────────────

model Insurer {
  id         String             @id @default(cuid())
  name       String             @unique   // "Sancor Seguros"
  slug       String             @unique   // "sancor-seguros"
  active     Boolean            @default(true)
  createdAt  DateTime           @default(now())
  users      InsurerUser[]
  apiKeys    InsurerApiKey[]
  siniestros Siniestro[]
  accessLogs InsurerAccessLog[]
}

model InsurerUser {
  id        String   @id @default(cuid())
  nombre    String
  email     String   @unique
  password  String
  insurerId String
  insurer   Insurer  @relation(fields: [insurerId], references: [id])
  createdAt DateTime @default(now())
}

model InsurerApiKey {
  id         String    @id @default(cuid())
  insurerId  String
  insurer    Insurer   @relation(fields: [insurerId], references: [id])
  hashedKey  String    @unique   // SHA-256 hex — nunca se guarda la key en claro
  label      String?
  revoked    Boolean   @default(false)
  lastUsedAt DateTime?
  createdAt  DateTime  @default(now())
}

// ─── Fotos ────────────────────────────────────────────────────────────────────

model SiniestroPhoto {
  id          String    @id @default(cuid())
  siniestroId String
  siniestro   Siniestro @relation(fields: [siniestroId], references: [id])
  storageKey  String    // path relativo en volumen — NUNCA URL pública
  mimeType    String
  takenAt     DateTime?
  latitude    Float?
  longitude   Float?
  createdAt   DateTime  @default(now())
}

// ─── Audit log ────────────────────────────────────────────────────────────────

model InsurerAccessLog {
  id          String    @id @default(cuid())
  insurerId   String
  insurer     Insurer   @relation(fields: [insurerId], references: [id])
  siniestroId String
  siniestro   Siniestro @relation(fields: [siniestroId], references: [id])
  via         String    // "PORTAL" | "API"
  userId      String?   // InsurerUser.id si via PORTAL
  apiKeyId    String?   // InsurerApiKey.id si via API
  createdAt   DateTime  @default(now())
}
